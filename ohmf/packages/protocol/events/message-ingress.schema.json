{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ohmf.local/schemas/message-ingress.schema.json",
  "title": "MessageIngressEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "message_id",
    "conversation_id",
    "sender_user_id",
    "idempotency_key",
    "endpoint",
    "content_type",
    "content",
    "transport_intent",
    "sent_at_ms",
    "trace_id"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "message_id": { "type": "string", "minLength": 1 },
    "conversation_id": { "type": "string", "minLength": 1 },
    "sender_user_id": { "type": "string", "minLength": 1 },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "endpoint": { "type": "string", "enum": ["/v1/messages", "/v1/messages/phone"] },
    "client_generated_id": { "type": "string" },
    "content_type": { "type": "string", "minLength": 1 },
    "content": { "type": "object", "additionalProperties": true },
    "transport_intent": { "type": "string", "enum": ["OHMF", "SMS"] },
    "recipient_phone": { "type": "string" },
    "sent_at_ms": { "type": "integer" },
    "trace_id": { "type": "string", "minLength": 1 }
  }
}
