{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ohmf.dev/schemas/miniapp/manifest.schema.json",
  "title": "OHMF Mini-App Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "app_id",
    "name",
    "version",
    "entrypoint",
    "message_preview",
    "permissions",
    "capabilities"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "app_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([.-][A-Za-z0-9]+)?$"
    },
    "entrypoint": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type",
        "url"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "url",
            "inline",
            "web_bundle"
          ]
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "icons": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "minLength": 1
          },
          "size": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          }
        }
      }
    },
    "message_preview": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type",
        "url"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "static_image",
            "live"
          ]
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "fit_mode": {
          "type": "string",
          "enum": [
            "scale",
            "crop"
          ]
        }
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "signature": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "alg",
            "kid",
            "sig"
          ],
          "properties": {
            "alg": {
              "type": "string",
              "minLength": 1
            },
            "kid": {
              "type": "string",
              "minLength": 1
            },
            "sig": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    }
  }
}
