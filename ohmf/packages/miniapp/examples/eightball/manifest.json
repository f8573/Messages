{
  "manifest_version": "1.0",
  "app_id": "app.ohmf.eightball",
  "name": "Mystic 8-Ball",
  "version": "1.0.0",
  "entrypoint": {
    "type": "url",
    "url": "https://example.com/miniapps/eightball/index.html",
    "mime_type": "text/html"
  },
  "icons": [
    { "src": "https://example.com/miniapps/eightball/icon-128.png", "sizes": "128x128", "type": "image/png" }
  ],
  "message_preview": {
    "type": "static_image",
    "url": "https://example.com/miniapps/eightball/preview-square.png",
    "alt_text": "Mystic 8-Ball conversation preview",
    "fit_mode": "scale"
  },
  "permissions": [
    "conversation.read_context",
    "conversation.send_message",
    "storage.session",
    "realtime.session"
  ],
  "capabilities": {
    "turn_based": true,
    "offline_resume": true,
    "host_message_projection": true
  },
  "metadata": {
    "category": "games",
    "summary": "Ask the shared 8-ball a question and project the answer into the thread."
  },
  "signature": {
    "alg": "RS256",
    "kid": "registry-key-1",
    "sig": "MEUCIQDnExampleSignatureBase64..."
  }
}
