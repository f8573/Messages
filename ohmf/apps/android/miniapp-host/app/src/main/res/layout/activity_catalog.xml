<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="16dp">

  <EditText
    android:id="@+id/api_base_input"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:hint="@string/api_base_hint"
    android:inputType="textUri" />

  <EditText
    android:id="@+id/bearer_token_input"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:hint="@string/bearer_token_hint"
    android:inputType="textPassword" />

  <Switch
    android:id="@+id/dev_mode_switch"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:text="@string/developer_mode" />

  <Button
    android:id="@+id/refresh_button"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:text="@string/refresh_catalog" />

  <TextView
    android:id="@+id/status_text"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:text="@string/catalog_idle" />

  <ListView
    android:id="@+id/catalog_list"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_marginTop="12dp"
    android:layout_weight="1" />
</LinearLayout>
